# ── API base URL ──────────────────────────────────────────────────────────────
# Leave blank for local development — Vite proxies /api to localhost:3000.
#
# Set this when building for production (points FE at your Fly.io backend):
# VITE_API_URL=https://your-api.fly.dev

# ── Dev remote API (optional) ─────────────────────────────────────────────────
# Set to "true" to point your LOCAL frontend at the DEPLOYED backend instead
# of localhost:3000. Useful for testing the frontend against production data
# without running the backend locally.
# VITE_DEV_REMOTE_API=true
