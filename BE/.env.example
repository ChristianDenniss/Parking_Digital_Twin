# ── App mode ──────────────────────────────────────────────────────────────────
# "local"      → SQLite DB, permissive CORS (default for development)
# "production" → PostgreSQL, origin-restricted CORS
APP_MODE=local

# ── Auth ──────────────────────────────────────────────────────────────────────
# Change this to a long random string in production
JWT_SECRET=dev-secret-change-in-production

# ── Database ──────────────────────────────────────────────────────────────────
# Only required when APP_MODE=production
# Example: postgresql://user:password@host:5432/dbname
# DATABASE_CONNECTION_STRING=

# ── CORS (production only) ────────────────────────────────────────────────────
# Set to your Vercel frontend URL when APP_MODE=production
# FRONTEND_ORIGIN=https://your-app.vercel.app

# ── Redis (optional) ──────────────────────────────────────────────────────────
# Prediction routes are cached with a 5-minute TTL when REDIS_URL is set.
# The app works without Redis — caching is simply skipped.
# REDIS_URL=redis://localhost:6379

# ── Google Earth Engine ───────────────────────────────────────────────────────
# The campus map needs a GEE service account. Without one, map tiles won't load
# but the rest of the app works fine.
#
# Option A: path to a service account JSON file (easiest for local dev)
# EARTH_ENGINE_SERVICE_ACCOUNT_PATH=./serviceAccount.json
#
# Option B: full JSON as a single-line string (useful for cloud environments)
# EARTH_ENGINE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
#
# Option C: split key (alternative to the JSON file)
# EARTH_ENGINE_CLIENT_EMAIL=my-account@my-project.iam.gserviceaccount.com
# EARTH_ENGINE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Simulator ─────────────────────────────────────────────────────────────────
# Override the simulated occupancy level (0.0 – 1.0).
# Leave unset for realistic random variation.
# SIM_OCCUPANCY=0.5
